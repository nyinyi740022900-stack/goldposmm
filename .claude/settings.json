{
  "permissions": {
    "allow": [
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter gen-l10n:*)",
      "Bash(flutter pub get:*)",
      "Bash(dart run build_runner build:*)",
      "Bash(dart run tool/:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(supabase migration list:*)",
      "Bash(gh repo view:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/secret-guard.sh\""
          }
        ]
      }
    ]
  }
}
